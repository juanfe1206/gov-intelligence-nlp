# Copy this file to ".env" and fill values locally.
# Do NOT commit your real ".env" file.

# --- Backend (FastAPI) ---
# Recommended: async SQLAlchemy URL format
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gov_intelligence

# Optional: explicitly configure pgvector usage (if your code needs a flag)
ENABLE_PGVECTOR=true

# --- LLM / Embeddings ---
# OpenAI API key (required if using OpenAI models)
OPENAI_API_KEY=

# Optional model defaults (adjust once you pick models)
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=

# --- App settings ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- Frontend (Next.js) ---
# If the frontend calls the backend from the browser, expose the API base URL:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

