# ===========================================
# GOV-INTELLIGENCE-NLP Environment Variables
# ===========================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# -------------------------------------------
# Database Configuration
# -------------------------------------------
# Supabase connection strings — find in: Project Settings → Database → Connection string
# Use "URI" for DATABASE_URL (asyncpg driver) and "URI" with postgresql:// for DATABASE_SYNC_URL
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.orntdllztsochjilskwm.supabase.co:5432/postgres
DATABASE_SYNC_URL=postgresql://postgres:[YOUR-PASSWORD]@db.orntdllztsochjilskwm.supabase.co:5432/postgres

# Local development fallback:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gov_intelligence_nlp
# DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/gov_intelligence_nlp

# -------------------------------------------
# LLM / AI Configuration
# -------------------------------------------
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# -------------------------------------------
# Processing Configuration
# -------------------------------------------
# LLM model defaults (adjust once you pick models)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PROCESSING_BATCH_SIZE=50
PROCESSING_MAX_RETRIES=3

# -------------------------------------------
# Taxonomy Configuration
# -------------------------------------------
TAXONOMY_PATH=config/taxonomy.yaml

# -------------------------------------------
# Ingestion Configuration
# -------------------------------------------
INGESTION_CSV_PATH=data/posts.csv
INGESTION_SOURCE_NAME=csv_local
INGESTION_PLATFORM_DEFAULT=

# -------------------------------------------
# Frontend Configuration
# -------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# For classroom access, set to the demo machine's IP: NEXT_PUBLIC_API_BASE_URL=http://192.168.1.42:8000
NEXT_PUBLIC_SUPABASE_URL=https://orntdllztsochjilskwm.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# -------------------------------------------
# Backend Configuration
# -------------------------------------------
# APP_ENV controls behavior: "dev" enables SQL echo logging, "demo"/"production" disables it
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:3000
# For classroom access, add the demo machine's IP: CORS_ALLOW_ORIGINS=http://192.168.1.42:3000,http://localhost:3000
BACKEND_HOST=127.0.0.1
# For classroom access, set to 0.0.0.0 so the backend accepts connections from other devices
# BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000