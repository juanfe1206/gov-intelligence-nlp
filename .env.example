# ===========================================
# GOV-INTELLIGENCE-NLP Environment Variables
# ===========================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# -------------------------------------------
# Database Configuration
# -------------------------------------------
# Supabase connection strings — find in: Project Settings → Database → Connection string
# Use "URI" for DATABASE_URL (asyncpg driver) and "URI" with postgresql:// for DATABASE_SYNC_URL
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.orntdllztsochjilskwm.supabase.co:5432/postgres
DATABASE_SYNC_URL=postgresql://postgres:[YOUR-PASSWORD]@db.orntdllztsochjilskwm.supabase.co:5432/postgres

# Local development fallback:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gov_intelligence_nlp
# DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/gov_intelligence_nlp

# -------------------------------------------
# LLM / AI Configuration
# -------------------------------------------
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Optional model defaults (adjust once you pick models)
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=

# -------------------------------------------
# Frontend Configuration
# -------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://orntdllztsochjilskwm.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# -------------------------------------------
# Backend Configuration
# -------------------------------------------
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:3000
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

