e="ingest", +                    status="failed", +                    started_at=datetime.now(timezone.utc), +                    finished_at=datetime.now(timezone.utc), +                    error_summary=["Original error"], +                ) +                session.add(job) +                await session.commit() +                return str(job.id) + +        import asyncio +        original_job_id = asyncio.run(create_failed_job()) + +        # Retry +        response = client.post(f"/jobs/{original_job_id}/retry") + +        # Original job should still exist with failed status +        async def check_original_job(): +            async with async_session_maker() as session: +                from sqlalchemy import select +                result = await session.execute(select(IngestionJob).where(IngestionJob.id == original_job_id)) +                job = result.scalar_one_or_none() +                return job.status if job else None + +        original_status = asyncio.run(check_original_job()) +        assert original_status == "failed"

